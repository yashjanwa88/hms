{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5001",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=identity_db;Username=postgres;Password=yash@9588;Pooling=true;MinPoolSize=5;MaxPoolSize=100;CommandTimeout=30"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForJWTTokenGeneration12345678",
    "ExpiryMinutes": 60
  },
  "RabbitMQ": {
    "HostName": "localhost"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/identity-service-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
