{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5008",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=doctor_db;Username=postgres;Password=yash@9588;Pooling=true;MinPoolSize=5;MaxPoolSize=100;CommandTimeout=30",
    "IdentityConnection": "Host=localhost;Port=5432;Database=identity_db;Username=postgres;Password=yash@9588"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyForJWTTokenGeneration12345678_Min32Chars!",
    "Issuer": "https://digitalhospital.local/identity",
    "Audience": "digitalhospital.api",
    "ExpiryMinutes": 60
  },
  "RabbitMQ": {
    "HostName": "localhost"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/doctor-service-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
